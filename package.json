{
  "name": "@openclaw/cloudflare-ai",
  "version": "0.1.0",
  "description": "OpenClaw plugin for Cloudflare Workers AI - audio transcription with Whisper models",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "check": "oxlint && tsc --noEmit"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "oxlint": "^0.15.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "keywords": [
    "openclaw",
    "plugin",
    "cloudflare",
    "whisper",
    "transcription",
    "speech-to-text"
  ]
}
