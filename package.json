{
  "name": "@kesor/openclaw-cloudflare-plugin",
  "version": "0.1.1",
  "description": "OpenClaw plugin for Cloudflare Workers AI - audio/image/video transcription and TTS",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "openclaw.plugin.json"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "test": "vitest",
    "check": "oxlint && tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "oxlint": "^0.15.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "keywords": [
    "openclaw",
    "plugin",
    "cloudflare",
    "workers-ai",
    "whisper",
    "llama",
    "transcription",
    "speech-to-text",
    "text-to-speech",
    "vision"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kesor/openclaw-cloudflare-media-ai-plugin.git"
  },
  "author": "",
  "license": "MIT"
}
